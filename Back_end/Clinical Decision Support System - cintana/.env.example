# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
APP_TITLE=Clinical Decision Support System
SECRET_KEY=change-me-to-a-long-random-secret-in-production

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cdss
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_CHARSET=utf8mb4

# ── Cache ─────────────────────────────────────────────────────────────────────
# TTL in seconds for in-memory cache
CACHE_TTL=300
